<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Local Assets</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('./partials/navbar') %>

    <main id="main" class="container">
      <%- include('partials/results') %>
      <h1>Local Assets</h1>
      <%- include('./partials/search', { currentSearch, activeTags }) %>
      
      <div class="tag-box">
        <% collections.forEach((collection) => { %>
          <%- include('./partials/tag', { tag: collection.name, activeTags, currentSearch }) %>
        <% }) %>
      </div>

      <% if (assets.length === 0) { %>
        <p class="empty-state">Nothing here.</p>
      <% } %>

      <section class="log-list" aria-live="polite">
        <% assets.forEach((asset) => { %>
          <%- include('./partials/asset', { asset, activeTags, currentSearch }) %>
        <% }) %>
      </section>
    </main>
  </body>
</html>
