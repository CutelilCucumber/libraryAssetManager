<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Asset Manager</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('./partials/navbar') %>

    <main id="main" class="container">
      <%- include('./partials/error') %>
      <h1>Add to Collection</h1>

      <form method="POST" action="/single" class="form">
        <h2 class="form-title">Single Asset</h2>
        <div class="form-group">
          <label class="path_input">
            Enter file path: 
            <input type="text" 
              class="form-input"
              name="filePath" 
              id="filePath" 
              value="<%= typeof asset !== 'undefined' && asset ? asset.file_path : '' %>"
              required 
              aria-required="true">
            </label>
            <p class="tooltip">Ie. /home/gldneye/Images/Assets/Landscape/Scenery/Mountain.png</p>
          </div>
          <div class="form-group">
          <label class="path_input">
            Select asset type: 
            <select name="fileType" id="fileType">
              <option value="feature">Map Feature</option>
              <option value="token">Character Token</option>
              <option value="other">Other</option>
            </select>
            </label>
          </div>
        <div class="form-group">
          <label>
            Add new tags: 
            <input type="text" 
              class="form-input"
              name="newTags" 
              id="newTags">
            </label>
            <p class="tooltip">Seperate multiple tags with a space.</p>
          </div>
      
       <div class="form-group">
        <span>Add existing tags:</span>
        <div class="tag-box">
      <% collections.forEach(collection => { %>
        <% const isSelected = typeof asset !== 'undefined' && asset && asset.tags.includes(collection.name) %>
        <label class="tag <%= isSelected ? 'tag--active' : '' %>">
          <input 
            type="checkbox" 
            name="existingTags" 
            value="<%= collection.name %>"
            <%= isSelected ? 'checked' : '' %>
            style="display: none;"
          />
          <p class="tag_text"><%= collection.name %></p>
        </label>
      <% }) %>
        </div>
      </div>
      <button type="submit" class="btn">Submit</button>
      </form>

      <form method="POST" action="/multiple" class="form">
        <h2 class="form-title">Collection Loader</h2>
        <p class="tooltip">The loader accepts a directory path, recursively walks every subfolder, and registers each folder as a tag in the database. Any image files it finds along the way are saved as assets and automatically tagged with every folder they are nested inside (Ie. anything inside Assets/Nature/Trees/ would receive the tags Assets, Nature, and Trees) Re-running it on the same directory is safe since it skips assets and collections that already exist.</p>
        <div class="form-group">
          <label>
            Enter folder path: 
            <input type="text" 
              class="form-input"
              name="dirPath" 
              id="dirPath" 
              required 
              aria-required="true">
            </label>
            <p class="tooltip">Ie. /home/gldneye/Images/Assets/Landscape</p>
          </div>
          <label>
            Select asset types: 
            <select name="fileType" id="fileType">
              <option value="feature">Map Feature</option>
              <option value="token">Character Token</option>
              <option value="other">Other</option>
            </select>
            </label>
          <button type="submit" class="btn">Submit</button>
          </form>
    </main>
  </body>

  <script>
  document.querySelectorAll('.tag input[type="checkbox"]').forEach(input => {
    input.addEventListener('change', () => {
      input.closest('.tag').classList.toggle('tag--active', input.checked);
    });
  });
</script>
</html>
