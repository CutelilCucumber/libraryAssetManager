<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Asset Library</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <%- include('partials/error') %>

  <main class="welcome">
    <div class="welcome__content">
      <h1 class="welcome__title">Asset Library Manager</h1>
      <p class="welcome__description">
        A personal tool for organising, tagging, and browsing local image assets.
        Import entire folder structures, filter by tags, and manage your library
        from one place. Cloud storage and shared libraries coming soon.
      </p>

      <div class="welcome__actions">
        <a href="/register" class="welcome__btn welcome__btn--primary">Get Started</a>
        <a href="/login" class="welcome__btn welcome__btn--secondary">Login</a>
      </div>
    </div>
  </main>

</body>
</html>