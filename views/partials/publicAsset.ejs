<article class="log" tabindex="0">
  <header class="log-header">
    <span class="name"><%= asset.name %></span>
    <time class="time" datetime="<%= asset.created %>">
      <%= new Date(asset.created).toLocaleString() %>
    </time>
  </header>
  <div class="asset-info">
    <img class="preview" src="/public/file/<%= asset.id %>" alt="asset preview">
    <div class="asset-text">
      <p class="text">Size: <%= asset.fileSize %> bytes</p>
      <p class="text">Type: <%= asset.type %></p>
      <p class="text">Owner: <%= asset.owner ? asset.owner.username : 'unknown' %></p>
    </div>
    <div class="asset-controls">
      <a href="/public/file/<%= asset.id %>" target="_blank">View</a>
      <a href="/public/file/<%= asset.id %>" download="<%= asset.name %>">Download</a>

      <% if (locals.user) { %>

        <%# remove from public — owner or admin %>
        <% if (locals.user.role === 'ADMIN' || asset.owner && asset.owner.id === locals.user.id) { %>
          <form action="/public/<%= asset.id %>/remove" method="POST">
            <button type="submit">Remove from Public</button>
          </form>
        <% } %>

        <%# delete entirely — admin only %>
        <% if (locals.user.role === 'ADMIN') { %>
          <form action="/public/<%= asset.id %>/delete" method="POST">
            <button type="submit">Delete</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>
  <div class="asset-tags">
    <% asset.tags.map((tag) => { %>
      <%- include("./tag", { tag, activeTags, currentSearch, basePath: "/public" }) %>
    <% }) %>
  </div>
</article>