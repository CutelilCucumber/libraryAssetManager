<% if (typeof results !== 'undefined' && results) { %>
<div class="result-banner">
  <svg class="result-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
    <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <div class="result-body">
    <p class="result-title">Import complete</p>
    <div class="result-stats">
      <div class="result-stat">
        <span class="result-stat-value"><%= results.inserted %></span>
        <span class="result-stat-label">inserted</span>
      </div>
      <div class="result-stat">
        <span class="result-stat-value"><%= results.skipped %></span>
        <span class="result-stat-label">skipped</span>
      </div>
    </div>
  </div>
  <button class="result-dismiss" onclick="this.closest('.result-banner').remove()">×</button>
</div>
<% } %>